<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.layover.course.CourseMapper">

    <resultMap id="CourseResultMap" type="com.ssafy.layover.course.Course">
        <id     column="id"                 property="id"/>
        <result column="user_id"            property="userId"/>
        <result column="departure_station"  property="departureStation"/>
        <result column="duration_minutes"   property="durationMinutes"/>
        <result column="travel_mode"        property="travelMode"/>
        <result column="weather_condition"  property="weatherCondition"/>
        <result column="theme_tags"         property="themeTags"/>
        <result column="is_public"          property="isPublic"/>
        <result column="created_at"         property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.ssafy.layover.course.Course">
        INSERT INTO courses
            (id, user_id, departure_station, duration_minutes,
             travel_mode, weather_condition, theme_tags, is_public, created_at)
        VALUES
            (#{id}, #{userId}, #{departureStation}, #{durationMinutes},
             #{travelMode}, #{weatherCondition}, #{themeTags}, #{isPublic}, #{createdAt})
    </insert>

    <select id="findByUserId" resultMap="CourseResultMap">
        SELECT * FROM courses
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="findAllPublic" resultMap="CourseResultMap">
        SELECT * FROM courses
        WHERE is_public = 1
        ORDER BY created_at DESC
    </select>

</mapper>
