<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.layover.notice.NoticeMapper">

    <resultMap id="NoticeListResultMap" type="com.ssafy.layover.notice.dto.NoticeListResponse">
        <result column="id"         property="id"/>
        <result column="title"      property="title"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <resultMap id="NoticeDetailResultMap" type="com.ssafy.layover.notice.dto.NoticeDetailResponse">
        <result column="id"         property="id"/>
        <result column="title"      property="title"/>
        <result column="content"    property="content"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findAll" resultMap="NoticeListResultMap">
        SELECT id, title, created_at
        FROM notices
        ORDER BY created_at DESC
    </select>

    <select id="findById" resultMap="NoticeDetailResultMap">
        SELECT id, title, content, created_at
        FROM notices
        WHERE id = #{id}
    </select>

</mapper>
